# LiveKit Cloud — cloud.livekit.io → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# SIP trunks
SIP_TRUNK_ID=ST_your_outbound_trunk_id
INBOUND_TRUNK_ID=ST_your_inbound_trunk_id

# Fixed English speaker — called when Sinhala caller dials in
TARGET_PHONE_NUMBER=+1XXXXXXXXXX

# Gemini API key — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-live-translate-preview
